NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key

# Recommended: store a hash instead of the raw admin password.
# Generate it with: node scripts/generate-admin-password-hash.mjs "your-strong-password"
ADMIN_PASSWORD_HASH=replace-with-generated-scrypt-hash

# Optional legacy fallback. Prefer ADMIN_PASSWORD_HASH.
# ADMIN_PASSWORD=set-a-strong-admin-password

ADMIN_SESSION_SECRET=set-a-long-random-admin-session-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
NEXT_PUBLIC_PAYPAL_PLAN_BASIC=your-paypal-basic-plan-id
NEXT_PUBLIC_PAYPAL_PLAN_PREMIUM=your-paypal-premium-plan-id
NEXT_PUBLIC_PAYPAL_PLAN_ULTIMATE=your-paypal-ultimate-plan-id
